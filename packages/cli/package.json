{
  "name": "@living-software/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Safe discovery, installation, diagnosis, and analysis CLI for Living Software hosts.",
  "license": "MIT",
  "bin": {
    "living": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test --test-isolation=none src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@living-software/automatic": "0.1.0",
    "@living-software/collector": "0.1.0",
    "@living-software/contracts": "0.1.0",
    "@living-software/discovery": "0.1.0",
    "@living-software/evolution": "0.1.0",
    "@living-software/installer": "0.1.0",
    "@living-software/intelligence": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
