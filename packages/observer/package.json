{
  "name": "@living-software/observer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Privacy-safe Next.js browser observer generator for Living Software.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test --test-isolation=none src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@living-software/contracts": "0.1.0"
  },
  "devDependencies": {
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
