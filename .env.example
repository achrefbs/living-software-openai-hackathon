# Optional: required only for the explicit Responses API path.
# `npm run demo:gpt56:api` requests gpt-5.6. The default authenticated
# Codex CLI path requests gpt-5.6-terra and does not read this key.
# Never commit a real key.
OPENAI_API_KEY=

# Optional human-facing link shown by captured-host Evolution Review.
# This does not grant Studio network access or prove runtime success.
LIVING_STUDIO_HOST_URL=http://127.0.0.1:3000/leads/lead-01

# The loopback evolution broker is enabled automatically in development.
# Leave this disabled unless you intentionally run the same local-only broker
# outside development; it is not a production deployment recommendation.
LIVING_STUDIO_EVOLUTION_ENABLED=0
