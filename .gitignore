# Dependencies
node_modules/

# Build and test output
.next/
dist/
coverage/
playwright-report/
test-results/

# The final package build is committed as the small, platform-neutral
# no-rebuild CLI judge distribution. Studio's .next output remains ignored.
!packages/*/dist/
packages/*/dist/*
!packages/*/dist/*.js

# Local databases and generated evidence
*.db
*.db-shm
*.db-wal
.living-software/
apps/studio/.local/

# Environment files and secrets
.env
.env.*
!.env.example

# Logs and editor files
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local judge credentials must never be committed
judge-credentials.*
