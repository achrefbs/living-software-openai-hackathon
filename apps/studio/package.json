{
  "name": "@living-software/studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Host-agnostic product intelligence and governed evolution studio.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --test-isolation=none tests/*.test.mjs tests/*.test.ts",
    "check": "npm run test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@living-software/cli": "0.1.0",
    "@living-software/collector": "0.1.0",
    "@living-software/contracts": "0.1.0",
    "@living-software/core": "0.1.0",
    "@living-software/evolution": "0.1.0",
    "@living-software/installer": "0.1.0",
    "@living-software/intelligence": "0.1.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
